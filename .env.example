# ============================================================
# SQL Agent Pro — Environment Configuration
# Default provider: Groq (fastest inference, free tier available)
# Get your key at: https://console.groq.com
# ============================================================

# --- Groq (default) ---
GROQ_API_KEY=gsk_...
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# --- Alternative providers (comment out Groq above and uncomment one) ---
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sql_agent_demo
DB_USER=sql_agent_readonly
DB_PASSWORD=readonly_password_change_me
DB_SCHEMA=public

# --- Connection Pool ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=schema_embeddings

# --- LangSmith Observability (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=sql-agent-pro
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Security ---
MAX_ROWS=1000
MAX_RETRIES=3
ENABLE_PII_MASKING=false

# --- Groq rate-limit safety (ms delay between retries) ---
GROQ_RETRY_DELAY=1.0

# --- App ---
APP_TITLE=SQL Agent Pro
APP_PORT=8501
ENV=development
LOG_LEVEL=INFO
